    "pre-commit": "lint-staged",
    "apollo:types": "graphql-codegen",
    "prepare": "husky"
  },
  "config": {
    "iconsServer": "https://fontello.com",
    "iconsConfig": "assets/fonts/icon/config.json",
    "iconsStyles": "styles/base",
    "iconsLocation": [
      "assets/fonts/icon"
    ]
  },
  "dependencies": {
    "@apollo/client": "^3.9.11",
