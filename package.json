    "deepmerge": "^4.2.2",
    "focus-visible": "^5.2.1",
    "graphql": "^16.8.1",
    "lodash": "^4.17.21",
    "next": "14.2.35",
    "next-intl": "^3.24.0",
    "nprogress": "^0.2.0",
    "react": "^18.2.0",
    "react-aria-components": "^1.1.1",
